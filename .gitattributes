# Normalize text files to LF on commit. Windows checkouts still get CRLF
# locally for files that .gitignore lets through, but the repo stays clean.
* text=auto eol=lf

# Shell scripts MUST be LF, otherwise they break on macOS/Linux.
gradlew text eol=lf

# Batch files MUST be CRLF, otherwise cmd.exe gets confused.
*.bat text eol=crlf

# Binary blobs — never touch.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.jar binary
*.apk binary
*.aab binary
*.keystore binary
*.jks binary

# Keep bundled manifest JSON out of language stats
app/src/main/assets/** linguist-vendored
